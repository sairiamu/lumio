{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "vibeplan",
  "version": "0.1.0",
  "identifier": "com.sairiamu.vibeplan",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "VibePlan",
        "width": 1280,
        "height": 800,
        "decorations": false,
        "zoomHotkeysEnabled": false,
        "visible": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDVEMjAzQTQwRTFDRjI3RjgKUldUNEo4L2hRRG9nWGZuRU1HNTg3ZFpUTVk3NEM2c3NmRy9zL2lyVlRQT1JEMlZQaUl6OXQ2VGQK",
      "endpoints": [
        "https://github.com/sairiamu/vibeplan/releases/latest/download/latest.json"
      ],
      "dialog": false
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/vibeplan.png",
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
