{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Lumio",
  "version": "1.5.0",
  "identifier": "com.lumio.app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Lumio",
        "width": 1280,
        "height": 800,
        "decorations": false,
        "zoomHotkeysEnabled": false,
        "visible": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {},
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/lumio.png",
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
